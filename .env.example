# Cổng chạy server
PORT=5000

# Connection string MongoDB Atlas
# Lấy từ Atlas: Database > Connect > Drivers > Node.js
# Nhớ thay <username>, <password>, <cluster-url> và tên database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/todo_app?retryWrites=true&w=majority&appName=todo-app

# Domain frontend được phép gọi API (CORS). Có thể liệt kê nhiều domain, cách nhau bởi dấu phẩy
CLIENT_ORIGIN=http://localhost:5173

# Môi trường chạy: development | production
NODE_ENV=development
